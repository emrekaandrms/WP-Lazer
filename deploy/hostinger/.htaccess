Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Force WordPress REST routes through PHP so nested bridge endpoints stay JSON.
RewriteRule ^wp-json/?$ index.php?rest_route=/ [QSA,L]
RewriteRule ^wp-json/(.*)$ index.php?rest_route=/$1 [QSA,L]

# Keep WordPress/WooCommerce internals handled by WordPress.
RewriteRule ^(wp-admin|wp-content|wp-includes)(/.*)?$ - [L]
RewriteRule ^(wp-login\.php|wp-cron\.php|xmlrpc\.php|index\.php)$ - [L]
RewriteRule ^odeme(/.*)?$ index.php [L]

# Serve the static export when a materialized file or directory exists.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
</IfModule>

# Anything else is NOT a WordPress page and NOT a real static file — serve our own branded
# 404 (from the Next.js static export) instead of falling through to WordPress, which would
# otherwise render the raw WP theme (unrelated default/demo content) for any typo'd URL.
ErrorDocument 404 /404.html
