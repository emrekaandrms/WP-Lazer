# Environment Configuration for WP-Lzer Headless Setup
# Copy this file to .env and fill in your values

# WordPress Environment
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
WP_DEBUG=1

# Database
DB_NAME=wp_lzer
DB_USER=wordpress
DB_PASSWORD=wordpress_secret
DB_HOST=wp-lzer-db:3306

# Headless Frontend
HEADLESS_FRONTEND_URL=http://localhost:3000

# GraphQL
GRAPHQL_JWT_AUTH_SECRET_KEY=your-secret-key-here-change-in-production
GRAPHQL_ENDPOINT=/graphql

# Security
WP_ENV=development
