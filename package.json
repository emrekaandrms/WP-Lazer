{
  "name": "wp-lzer",
  "version": "1.0.0",
  "description": "Headless WooCommerce with WordPress, WPGraphQL, and Next.js",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run seo:generate && npm run build --workspace=frontend",
    "validate": "node scripts/validate-content.js",
    "seo:generate": "node scripts/generate-seo-assets.js",
    "products:transform:htc": "node scripts/transform-htc-products.js",
    "products:images": "python3 scripts/merge_product_images.py",
    "products:content": "python3 scripts/enrich_product_content.py",
    "products:import": "node scripts/import-products.js",
    "hostinger:build": "npm run validate && npm run seo:generate && npm run build --workspace=frontend",
    "deploy": "bash deploy/deploy.sh"
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "read-excel-file": "^9.0.6"
  },
  "overrides": {
    "postcss": "8.5.12"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
