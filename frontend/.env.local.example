# Frontend Environment Variables
# Copy to .env.local and fill in values

# WordPress GraphQL Endpoint
WP_GRAPHQL_URL=http://localhost:8080/graphql

# WordPress Site URL (for absolute URLs in content)
WP_HOME=http://localhost:8080

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_REVALIDATE_SECRET=your-revalidate-secret-change-in-production

# ISR Revalidation (seconds)
ISR_REVALIDATE_PRODUCT=60
ISR_REVALIDATE_CATEGORY=300
ISR_REVALIDATE_PAGE=3600
ISR_REVALIDATE_POLICY=86400
